# Codex Ops — local environment.
# Copy to `.env` (gitignored) for local `vite dev`. Without a key, the agent
# uses a deterministic mock so the app still works end to end.

# Your OpenAI API key (server-side only; never exposed to the client).
OPENAI_API_KEY=

# Optional: override the model used by the agent.
OPENAI_MODEL=gpt-4o-mini
